{
  "name": "monkbrowse-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "package:extension": "turbo run package --filter=@monkbrowse/extension",
    "doctor": "bun run --cwd apps/server doctor",
    "dev:server": "turbo run dev --filter=@monkbrowse/server",
    "dev:extension": "turbo run dev --filter=@monkbrowse/extension"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.2"
  }
}
